#include<pic.h>
#define RS RC5
#define RW RC6
#define EN RC7
void interrupt tmr(void);
void adcbegin();
void lcd_data(unsigned char);
void lcd_command(unsigned char);
void tempdisplay(unsigned int);
void pwmgen(int,int);
int temp=0;
float val=0;
int a,b,c;
void delay(unsigned int x)
{
while(x--);
}
void lcd_string(unsigned char l[])
{
for(int i=0;l[i]!='\0';i++)
{
lcd_data(l[i]);
}
}
void adcbegin()
{
ADCON0 = ADCON0 | 0x04;
while(ADCON0 & 0x04);
temp = ((ADRESH << 8) + ADRESL);
val=temp*5.0/(1024.0);
temp=val*100;
lcd_command(0XC0);
lcd_string("Temp - ");
tempdisplay(temp);
lcd_string("�C");
delay(100);
}
void interrupt tmr(void)
{
if(TMR0IF==1)
{
TMR0IF=0;
c=1;
TMR0=0XC4;
}
}
void lcd_command(unsigned char m)
{
PORTB=m;
RS=0;
RW=0;
EN=1;
delay(100);
EN=0;
}
void lcd_data(unsigned char k)
{
PORTB=k;
RS=1;
RW=0;
EN=1;
delay(100);
EN=0;
}
void lcd_init()
{
lcd_command(0X38);
lcd_command(0X0C);
lcd_command(0X01);
lcd_command(0X06);
}
void tempdisplay(unsigned int a)
{
int res=0;
res=a/10;
lcd_data(res+'0');
res=a%10;
lcd_data(res+'0');
}
void pwmgen(int a,int b)
{
CCPR1L=a;
PR2=b;
}
main()
{
TRISA=0X01;
PORTA=0X00;
TRISB=0X00;
PORTB=0X00;
TRISC=0X00;
PORTC=0X00;
ADCON1=0x80;    
ADCON0=0x41;
T0CS=0;
T0SE=0;
PSA=0;
PS2=1;PS1=1;PS0=0;
GIE=1;
PEIE=1;
TMR0IE=1;
TMR0=0XC4;
T2CON=0X01;
CCP1CON=0X0C;
TMR2=0X00;
lcd_init();
while(1)
{
if(c)
{
adcbegin();
c=0;
}
if(temp>25 && temp<35)
{
lcd_command(0X80);
lcd_string("Low  speed");
pwmgen(4,12);
}
else if(temp >35 && temp<50)
{
lcd_command(0X80);
lcd_string("Med  speed");
pwmgen(6,12);
}
else if(temp>50)
{
lcd_command(0X80);
lcd_string("High speed");
pwmgen(8,12);
}
}
}
